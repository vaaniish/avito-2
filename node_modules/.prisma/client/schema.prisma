generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum NotificationType {
  NEW_QUESTION
  ORDER_STATUS
  SYSTEM
  INFO
}

enum ListingType {
  PRODUCT
  SERVICE
}

enum ListingCondition {
  NEW
  USED
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  MODERATION
}

enum ModerationStatus {
  APPROVED
  REJECTED
  PENDING
}

enum QuestionStatus {
  PENDING
  ANSWERED
}

enum OrderStatus {
  CREATED
  PAID
  PROCESSING
  PREPARED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

enum TransactionStatus {
  PENDING
  HELD
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  YOOMONEY
  STRIPE
  OTHER
}

enum ComplaintStatus {
  NEW
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintSanctionLevel {
  WARNING
  TEMP_3_DAYS
  TEMP_30_DAYS
  PERMANENT
}

enum ComplaintSanctionStatus {
  ACTIVE
  COMPLETED
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SellerType {
  COMPANY
  PRIVATE
  INDIVIDUAL
  IP
  BRAND
  ADMIN_APPROVED
}

enum PartnershipRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PolicyScope {
  CHECKOUT
  PARTNERSHIP
}

enum PayoutProfileStatus {
  PENDING
  VERIFIED
  REJECTED
}

model AppUser {
  id            Int        @id @default(autoincrement())
  public_id     String     @unique
  role          UserRole
  status        UserStatus @default(ACTIVE)
  email         String     @unique
  password      String
  name          String
  first_name    String?
  last_name     String?
  display_name  String?
  username      String?    @unique
  phone         String?
  avatar        String?
  block_reason  String?
  blocked_until DateTime?
  joined_at     DateTime   @default(now())
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  seller_profile                SellerProfile?
  addresses                     UserAddress[]
  listings                      MarketplaceListing[]     @relation("seller_listings")
  wishlist_items                WishlistItem[]
  orders_as_buyer               MarketOrder[]            @relation("buyer_orders")
  orders_as_seller              MarketOrder[]            @relation("seller_orders")
  transactions_buyer            PlatformTransaction[]    @relation("buyer_transactions")
  transactions_seller           PlatformTransaction[]    @relation("seller_transactions")
  questions_asked               ListingQuestion[]        @relation("question_author")
  complaints_reported           Complaint[]              @relation("complaint_reporter")
  complaints_against            Complaint[]              @relation("complaint_seller")
  checked_complaints            Complaint[]              @relation("complaint_checker")
  kyc_requests                  KycRequest[]             @relation("kyc_seller")
  reviewed_kyc                  KycRequest[]             @relation("kyc_reviewer")
  partnership_requests          PartnershipRequest[]
  reviewed_partnership_requests PartnershipRequest[]     @relation("partnership_reviewer")
  reviews                       ListingReview[]          @relation("user_reviews")
  notifications                 Notification[]
  audit_logs                    AuditLog[]               @relation("audit_actor")
  order_status_changes          OrderStatusHistory[]     @relation("order_status_actor")
  complaint_sanctions_received  ComplaintSanction[]      @relation("complaint_sanction_seller")
  complaint_sanctions_created   ComplaintSanction[]      @relation("complaint_sanction_admin")
  complaint_events              ComplaintEvent[]         @relation("complaint_event_actor")
  admin_idempotency_keys        AdminIdempotencyKey[]    @relation("admin_idempotency_actor")
  checkout_idempotency_keys     CheckoutIdempotencyKey[] @relation("checkout_idempotency_actor")
  policy_acceptances            PolicyAcceptance[]
  payout_profile                SellerPayoutProfile?
  payout_profiles_reviewed      SellerPayoutProfile[]    @relation("payout_profile_reviewer")

  @@index([role, status])
  @@index([created_at])
}

model Notification {
  id         Int              @id @default(autoincrement())
  user_id    Int
  type       NotificationType
  message    String
  target_url String
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now())

  user AppUser @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
}

model SellerProfile {
  id                       Int      @id @default(autoincrement())
  user_id                  Int      @unique
  is_verified              Boolean  @default(false)
  average_response_minutes Int?
  commission_tier_id       Int?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  user            AppUser         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  commission_tier CommissionTier? @relation(fields: [commission_tier_id], references: [id], onDelete: SetNull)

  @@index([commission_tier_id])
}

model UserAddress {
  id           Int      @id @default(autoincrement())
  user_id      Int
  label        String
  full_address String
  region       String
  city         String
  street       String
  house        String
  apartment    String?  @default("")
  entrance     String?  @default("")
  postal_code  String
  lat          Float?
  lon          Float?
  is_default   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user AppUser @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, label])
  @@index([user_id, is_default])
}

model CatalogCategory {
  id          Int         @id @default(autoincrement())
  public_id   String      @unique
  type        ListingType
  name        String
  icon_key    String
  order_index Int         @default(0)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  subcategories CatalogSubcategory[]

  @@unique([type, name])
}

model CatalogSubcategory {
  id          Int      @id @default(autoincrement())
  category_id Int
  public_id   String   @unique
  name        String
  order_index Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category CatalogCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  items    CatalogItem[]

  @@unique([category_id, name])
}

model CatalogItem {
  id             Int      @id @default(autoincrement())
  subcategory_id Int
  public_id      String   @unique
  name           String
  order_index    Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  subcategory CatalogSubcategory   @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)
  listings    MarketplaceListing[]

  @@unique([subcategory_id, name])
}

model MarketplaceListing {
  id                 Int              @id @default(autoincrement())
  public_id          String           @unique
  seller_id          Int
  type               ListingType
  title              String
  description        String?
  item_id            Int?
  price              Int
  sale_price         Int?
  rating             Float            @default(4.5)
  condition          ListingCondition
  status             ListingStatus    @default(ACTIVE)
  moderation_status  ModerationStatus @default(APPROVED)
  views              Int              @default(0)
  shipping_by_seller Boolean          @default(true)
  sku                String?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  seller         AppUser            @relation("seller_listings", fields: [seller_id], references: [id], onDelete: Cascade)
  item           CatalogItem?       @relation(fields: [item_id], references: [id], onDelete: SetNull)
  images         ListingImage[]
  attributes     ListingAttribute[]
  reviews        ListingReview[]
  questions      ListingQuestion[]
  complaints     Complaint[]
  order_items    MarketOrderItem[]
  wishlist_items WishlistItem[]

  @@index([seller_id])
  @@index([item_id])
  @@index([type, status, moderation_status])
  @@index([status, moderation_status, created_at])
  @@index([type, status, moderation_status, created_at(sort: Desc), id(sort: Desc)], map: "MarketplaceListing_type_status_moderation_created_id_idx")
}

model ListingImage {
  id         Int      @id @default(autoincrement())
  listing_id Int
  url        String
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([listing_id, sort_order])
}

model ListingAttribute {
  id         Int    @id @default(autoincrement())
  listing_id Int
  key        String
  value      String
  sort_order Int    @default(0)

  listing MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([listing_id, key], map: "ListingAttribute_listing_id_attr_key")
  @@index([listing_id])
}

model ListingReview {
  id         Int      @id @default(autoincrement())
  listing_id Int
  author_id  Int
  rating     Int
  comment    String
  created_at DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  author  AppUser            @relation("user_reviews", fields: [author_id], references: [id], onDelete: Cascade)

  @@unique([listing_id, author_id])
  @@index([listing_id, created_at])
}

model ListingQuestion {
  id          Int            @id @default(autoincrement())
  public_id   String         @unique
  listing_id  Int
  buyer_id    Int
  question    String
  answer      String?
  status      QuestionStatus @default(PENDING)
  created_at  DateTime       @default(now())
  answered_at DateTime?

  listing MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  buyer   AppUser            @relation("question_author", fields: [buyer_id], references: [id], onDelete: Cascade)

  @@index([listing_id, created_at])
}

model WishlistItem {
  id         Int      @id @default(autoincrement())
  user_id    Int
  listing_id Int
  added_at   DateTime @default(now())

  user    AppUser            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([user_id, listing_id])
}

model MarketOrder {
  id                  Int          @id @default(autoincrement())
  public_id           String       @unique
  buyer_id            Int
  seller_id           Int
  status              OrderStatus  @default(CREATED)
  delivery_type       DeliveryType
  delivery_address    String?
  tracking_provider   String?
  tracking_number     String?
  tracking_url        String?
  delivery_ext_status String?
  delivery_checked_at DateTime?
  delivered_at        DateTime?
  issued_at           DateTime?
  total_price         Int
  delivery_cost       Int          @default(0)
  discount            Int          @default(0)
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  buyer          AppUser               @relation("buyer_orders", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller         AppUser               @relation("seller_orders", fields: [seller_id], references: [id], onDelete: Cascade)
  items          MarketOrderItem[]
  transactions   PlatformTransaction[]
  status_history OrderStatusHistory[]

  @@index([buyer_id])
  @@index([seller_id])
  @@index([status, created_at])
  @@index([delivery_type, status, delivery_checked_at])
}

model MarketOrderItem {
  id         Int     @id @default(autoincrement())
  order_id   Int
  listing_id Int?
  name       String
  image      String?
  price      Int
  quantity   Int

  order   MarketOrder         @relation(fields: [order_id], references: [id], onDelete: Cascade)
  listing MarketplaceListing? @relation(fields: [listing_id], references: [id], onDelete: SetNull)

  @@unique([order_id, listing_id], map: "MarketOrderItem_order_listing_unique")
  @@index([order_id])
  @@index([listing_id])
}

model PlatformTransaction {
  id                Int               @id @default(autoincrement())
  public_id         String            @unique
  order_id          Int
  buyer_id          Int
  seller_id         Int
  amount            Int
  status            TransactionStatus
  commission_rate   Float
  commission        Int
  payment_provider  PaymentProvider
  payment_intent_id String            @unique
  created_at        DateTime          @default(now())

  order  MarketOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  buyer  AppUser     @relation("buyer_transactions", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller AppUser     @relation("seller_transactions", fields: [seller_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([buyer_id])
  @@index([seller_id])
  @@index([status, created_at])
}

model Complaint {
  id             Int             @id @default(autoincrement())
  public_id      String          @unique
  created_at     DateTime        @default(now())
  status         ComplaintStatus @default(NEW)
  complaint_type String
  listing_id     Int
  seller_id      Int
  reporter_id    Int
  description    String
  evidence       String?
  checked_at     DateTime?
  checked_by_id  Int?
  action_taken   String?

  listing    MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  seller     AppUser            @relation("complaint_seller", fields: [seller_id], references: [id], onDelete: Cascade)
  reporter   AppUser            @relation("complaint_reporter", fields: [reporter_id], references: [id], onDelete: Cascade)
  checked_by AppUser?           @relation("complaint_checker", fields: [checked_by_id], references: [id], onDelete: SetNull)
  sanction   ComplaintSanction?
  events     ComplaintEvent[]

  @@index([status])
  @@index([listing_id])
  @@index([status, created_at(sort: Desc), id(sort: Desc)], map: "Complaint_status_created_at_id_idx")
  @@index([listing_id, status, created_at(sort: Desc), id(sort: Desc)], map: "Complaint_listing_status_created_at_id_idx")
}

model ComplaintEvent {
  id            Int              @id @default(autoincrement())
  public_id     String           @unique
  complaint_id  Int
  actor_user_id Int?
  event_type    String
  from_status   ComplaintStatus?
  to_status     ComplaintStatus?
  note          String?
  metadata      Json?
  created_at    DateTime         @default(now())

  complaint Complaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)
  actor     AppUser?  @relation("complaint_event_actor", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([complaint_id, created_at])
  @@index([actor_user_id, created_at])
}

model AdminIdempotencyKey {
  id              Int      @id @default(autoincrement())
  public_id       String   @unique
  actor_user_id   Int
  action          String
  idempotency_key String
  request_hash    String
  response_status Int?
  response_body   Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  actor AppUser @relation("admin_idempotency_actor", fields: [actor_user_id], references: [id], onDelete: Cascade)

  @@unique([actor_user_id, action, idempotency_key], map: "AdminIdempotency_actor_action_key_unique")
  @@index([created_at])
}

model CheckoutIdempotencyKey {
  id              Int      @id @default(autoincrement())
  public_id       String   @unique
  actor_user_id   Int
  action          String
  idempotency_key String
  request_hash    String
  response_status Int?
  response_body   Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  actor AppUser @relation("checkout_idempotency_actor", fields: [actor_user_id], references: [id], onDelete: Cascade)

  @@unique([actor_user_id, action, idempotency_key], map: "CheckoutIdempotency_actor_action_key_unique")
  @@index([created_at])
}

model ComplaintSanction {
  id            Int                     @id @default(autoincrement())
  public_id     String                  @unique
  complaint_id  Int                     @unique
  seller_id     Int
  level         ComplaintSanctionLevel
  status        ComplaintSanctionStatus @default(ACTIVE)
  reason        String
  starts_at     DateTime                @default(now())
  ends_at       DateTime?
  created_by_id Int?
  created_at    DateTime                @default(now())
  updated_at    DateTime                @updatedAt

  complaint  Complaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)
  seller     AppUser   @relation("complaint_sanction_seller", fields: [seller_id], references: [id], onDelete: Cascade)
  created_by AppUser?  @relation("complaint_sanction_admin", fields: [created_by_id], references: [id], onDelete: SetNull)

  @@index([seller_id, status, created_at])
  @@index([created_by_id])
}

model KycRequest {
  id               Int       @id @default(autoincrement())
  public_id        String    @unique
  created_at       DateTime  @default(now())
  status           KycStatus @default(PENDING)
  seller_id        Int
  email            String
  phone            String
  company_name     String
  inn              String
  address          String
  documents        String?
  notes            String?
  reviewed_by_id   Int?
  reviewed_at      DateTime?
  rejection_reason String?

  seller      AppUser  @relation("kyc_seller", fields: [seller_id], references: [id], onDelete: Cascade)
  reviewed_by AppUser? @relation("kyc_reviewer", fields: [reviewed_by_id], references: [id], onDelete: SetNull)

  @@index([status, created_at])
}

model CommissionTier {
  id              Int      @id @default(autoincrement())
  public_id       String   @unique
  name            String
  min_sales       Int
  max_sales       Int?
  commission_rate Float
  description     String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  seller_profiles SellerProfile[]

  @@index([min_sales, max_sales])
}

model PartnershipRequest {
  id               Int                      @id @default(autoincrement())
  public_id        String                   @unique
  user_id          Int
  seller_type      SellerType
  status           PartnershipRequestStatus @default(PENDING)
  name             String
  email            String
  contact          String
  link             String
  category         String
  inn              String?
  geography        String?
  social_profile   String?
  credibility      String?
  why_us           String
  reviewed_by_id   Int?
  reviewed_at      DateTime?
  rejection_reason String?
  admin_note       String?
  created_at       DateTime                 @default(now())

  user        AppUser  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reviewed_by AppUser? @relation("partnership_reviewer", fields: [reviewed_by_id], references: [id], onDelete: SetNull)

  @@index([status, created_at])
  @@index([reviewed_by_id])
  @@index([created_at])
}

model PlatformPolicy {
  id           Int         @id @default(autoincrement())
  public_id    String      @unique
  scope        PolicyScope
  version      String
  title        String
  content_url  String
  is_active    Boolean     @default(true)
  activated_at DateTime    @default(now())
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  acceptances PolicyAcceptance[]

  @@unique([scope, version], map: "PlatformPolicy_scope_version_unique")
  @@index([scope, is_active, activated_at(sort: Desc)])
}

model PolicyAcceptance {
  id          Int      @id @default(autoincrement())
  policy_id   Int
  user_id     Int
  accepted_at DateTime @default(now())
  accepted_ip String?
  accepted_ua String?

  policy PlatformPolicy @relation(fields: [policy_id], references: [id], onDelete: Cascade)
  user   AppUser        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([policy_id, user_id], map: "PolicyAcceptance_policy_user_unique")
  @@index([user_id, accepted_at])
}

model SellerPayoutProfile {
  id                    Int                 @id @default(autoincrement())
  public_id             String              @unique
  seller_id             Int                 @unique
  legal_type            SellerType
  legal_name            String
  tax_id                String
  bank_account          String
  bank_bic              String
  correspondent_account String
  bank_name             String
  recipient_name        String
  status                PayoutProfileStatus @default(PENDING)
  verified_by_id        Int?
  verified_at           DateTime?
  rejection_reason      String?
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt

  seller      AppUser  @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  verified_by AppUser? @relation("payout_profile_reviewer", fields: [verified_by_id], references: [id], onDelete: SetNull)

  @@index([status, updated_at(sort: Desc)])
  @@index([verified_by_id, updated_at(sort: Desc)])
}

model OrderStatusHistory {
  id            Int          @id @default(autoincrement())
  order_id      Int
  from_status   OrderStatus?
  to_status     OrderStatus
  changed_by_id Int?
  reason        String?
  created_at    DateTime     @default(now())

  order      MarketOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  changed_by AppUser?    @relation("order_status_actor", fields: [changed_by_id], references: [id], onDelete: SetNull)

  @@index([order_id, created_at])
  @@index([changed_by_id])
}

model AuditLog {
  id               Int      @id @default(autoincrement())
  public_id        String   @unique
  actor_user_id    Int?
  action           String
  entity_type      String
  entity_public_id String?
  details          Json?
  ip_address       String?
  created_at       DateTime @default(now())

  actor AppUser? @relation("audit_actor", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([actor_user_id, created_at])
  @@index([entity_type, entity_public_id])
  @@index([action, created_at])
}
