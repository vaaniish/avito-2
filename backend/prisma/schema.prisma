model SellerCommissionPeriodStat {
  id                Int            @id @default(autoincrement())
  public_id         String         @unique
  seller_id         Int
  period_key        String
  period_start      DateTime
  period_end        DateTime
  gross             Int            @default(0)
  commission_total  Int            @default(0)
  seller_profit     Int            @default(0)
  payable           Int            @default(0)
  held              Int            @default(0)
  refunded_cancelled Int           @default(0)
  qualified_gmv     Int            @default(0)
  completed_orders  Int            @default(0)
  successful_transactions Int      @default(0)
  total_transactions Int           @default(0)
  current_tier_id   Int?
  next_tier_id      Int?
  sales_to_next_tier Int           @default(0)
  percent_to_next_tier Float       @default(0)
  commission_rate_at_period_end Float @default(0)
  snapshot_finalized_at DateTime?
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  seller            AppUser        @relation("seller_commission_period_stats", fields: [seller_id], references: [id], onDelete: Cascade)
  current_tier      CommissionTier? @relation(fields: [current_tier_id], references: [id], onDelete: SetNull)
  next_tier         CommissionTier? @relation("next_commission_tier_stats", fields: [next_tier_id], references: [id], onDelete: SetNull)

  @@unique([seller_id, period_key], map: "SellerCommissionPeriodStat_seller_period_key_unique")
  @@index([seller_id, period_start])
  @@index([current_tier_id])
  @@index([next_tier_id])
}

