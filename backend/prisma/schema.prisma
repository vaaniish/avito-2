generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum NotificationType {
  NEW_QUESTION
  ORDER_STATUS
  SYSTEM
  INFO
}

enum ListingType {
  PRODUCT
}

enum ListingCondition {
  NEW
  USED
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  MODERATION
}

enum ModerationStatus {
  APPROVED
  REJECTED
  PENDING
}

enum QuestionStatus {
  PENDING
  ANSWERED
}

enum OrderStatus {
  CREATED
  PAID
  PROCESSING
  PREPARED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

enum TransactionStatus {
  PENDING
  HELD
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  YOOMONEY
  STRIPE
  OTHER
}

enum ComplaintStatus {
  NEW
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintSanctionLevel {
  WARNING
  TEMP_3_DAYS
  TEMP_30_DAYS
  PERMANENT
}

enum ComplaintSanctionStatus {
  ACTIVE
  COMPLETED
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SellerType {
  COMPANY
  PRIVATE
  INDIVIDUAL
  IP
  BRAND
  ADMIN_APPROVED
}

enum PartnershipRequestStatus {
  DRAFT
  SUBMITTED
  LEGAL_REVIEW
  REPRESENTATIVE_REVIEW
  PAYOUT_REVIEW
  QUALITY_REVIEW
  APPROVED_LIMITED
  NEEDS_MORE_INFO
  PENDING
  APPROVED
  REJECTED
}

enum PolicyScope {
  CHECKOUT
  PARTNERSHIP
}

enum PayoutProfileStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ListingModerationActorType {
  SYSTEM
  ADMIN
}

enum ListingModerationDecision {
  QUEUED
  AUTO_APPROVED
  AUTO_REVIEW
  APPROVED
  REJECTED
}

enum CatalogSuggestionEntityType {
  CATEGORY
  SUBCATEGORY
  ITEM
  MANUFACTURER
  MODEL
  ATTRIBUTE_VALUE
  ATTRIBUTE_SCHEMA
}

enum CatalogSuggestionStatus {
  PENDING
  AUTO_APPROVED
  APPROVED
  REJECTED
  MERGED
}

model AppUser {
  id                   Int                   @id @default(autoincrement())
  public_id            String                @unique
  role                 UserRole
  status               UserStatus            @default(ACTIVE)
  email                String                @unique
  password             String
  name                 String
  first_name           String?
  last_name            String?
  display_name         String?
  username             String?               @unique
  phone                String?
  avatar               String?
  block_reason         String?
  blocked_until        DateTime?
  joined_at            DateTime              @default(now())
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt

  seller_profile       SellerProfile?
  addresses            UserAddress[]
  listings             MarketplaceListing[]  @relation("seller_listings")
  wishlist_items       WishlistItem[]
  orders_as_buyer      MarketOrder[]         @relation("buyer_orders")
  orders_as_seller     MarketOrder[]         @relation("seller_orders")
  transactions_buyer   PlatformTransaction[] @relation("buyer_transactions")
  transactions_seller  PlatformTransaction[] @relation("seller_transactions")
  questions_asked      ListingQuestion[]     @relation("question_author")
  complaints_reported  Complaint[]           @relation("complaint_reporter")
  complaints_against   Complaint[]           @relation("complaint_seller")
  checked_complaints   Complaint[]           @relation("complaint_checker")
  kyc_requests         KycRequest[]          @relation("kyc_seller")
  reviewed_kyc         KycRequest[]          @relation("kyc_reviewer")
  partnership_requests PartnershipRequest[]
  reviewed_partnership_requests PartnershipRequest[] @relation("partnership_reviewer")
  catalog_suggestions  CatalogSuggestion[]   @relation("catalog_suggestion_proposer")
  reviews              ListingReview[]       @relation("user_reviews")
  notifications        Notification[]
  audit_logs           AuditLog[]            @relation("audit_actor")
  order_status_changes OrderStatusHistory[]  @relation("order_status_actor")
  complaint_sanctions_received ComplaintSanction[] @relation("complaint_sanction_seller")
  complaint_sanctions_created  ComplaintSanction[] @relation("complaint_sanction_admin")
  complaint_events     ComplaintEvent[]      @relation("complaint_event_actor")
  listing_moderation_events ListingModerationEvent[] @relation("listing_moderation_actor")
  admin_idempotency_keys AdminIdempotencyKey[] @relation("admin_idempotency_actor")
  checkout_idempotency_keys CheckoutIdempotencyKey[] @relation("checkout_idempotency_actor")
  policy_acceptances   PolicyAcceptance[]
  payout_profile       SellerPayoutProfile?
  payout_profiles_reviewed SellerPayoutProfile[] @relation("payout_profile_reviewer")
  listing_drafts       ListingDraft[]       @relation("seller_listing_drafts")
  commission_period_stats SellerCommissionPeriodStat[] @relation("seller_commission_period_stats")

  @@index([role, status])
  @@index([created_at])
}

model Notification {
  id          Int              @id @default(autoincrement())
  user_id     Int
  type        NotificationType
  message     String
  target_url  String
  is_read     Boolean          @default(false)
  created_at  DateTime         @default(now())

  user        AppUser          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
}

model SellerProfile {
  id                       Int             @id @default(autoincrement())
  user_id                  Int             @unique
  is_verified              Boolean         @default(false)
  average_response_minutes Int?
  commission_tier_id       Int?
  created_at               DateTime        @default(now())
  updated_at               DateTime        @updatedAt

  user                     AppUser         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  commission_tier          CommissionTier? @relation(fields: [commission_tier_id], references: [id], onDelete: SetNull)

  @@index([commission_tier_id])
}

model UserAddress {
  id          Int      @id @default(autoincrement())
  user_id     Int
  label       String
  full_address String
  region      String
  city        String
  street      String
  house       String
  apartment   String?  @default("")
  entrance    String?  @default("")
  postal_code String
  lat         Float?
  lon         Float?
  is_default  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        AppUser  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, label])
  @@index([user_id, is_default])
}

model CatalogCategory {
  id            Int                  @id @default(autoincrement())
  public_id     String               @unique
  type          ListingType
  name          String
  icon_key      String
  order_index   Int                  @default(0)
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt

  subcategories CatalogSubcategory[]
  attribute_definitions CatalogAttributeDefinition[]
  suggestions    CatalogSuggestion[] @relation("catalog_suggestion_category")
  search_rules   CatalogSearchRule[]

  @@unique([type, name])
}

model CatalogSubcategory {
  id             Int              @id @default(autoincrement())
  category_id    Int
  public_id      String           @unique
  name           String
  order_index    Int              @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  category       CatalogCategory  @relation(fields: [category_id], references: [id], onDelete: Cascade)
  items          CatalogItem[]
  attribute_definitions CatalogAttributeDefinition[]
  suggestions    CatalogSuggestion[] @relation("catalog_suggestion_subcategory")
  search_rules   CatalogSearchRule[]

  @@unique([category_id, name])
}

model CatalogItem {
  id             Int                @id @default(autoincrement())
  subcategory_id Int
  public_id      String             @unique
  name           String
  order_index    Int                @default(0)
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt

  subcategory    CatalogSubcategory @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)
  listings       MarketplaceListing[]
  attribute_definitions CatalogAttributeDefinition[]
  reference_brands CatalogReferenceBrand[]
  suggestions    CatalogSuggestion[] @relation("catalog_suggestion_item")
  search_rules   CatalogSearchRule[]

  @@unique([subcategory_id, name])
}

model CatalogSearchRule {
  id                 Int                 @id @default(autoincrement())
  public_id          String              @unique
  phrase             String
  normalized_phrase  String
  category_id        Int?
  subcategory_id     Int?
  item_id            Int?
  brand_name         String?
  normalized_brand   String?
  model_name         String?
  normalized_model   String?
  characteristic_key String?
  characteristic_value String?
  weight             Int                 @default(50)
  is_generated       Boolean             @default(false)
  source             String              @default("manual")
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt

  category           CatalogCategory?    @relation(fields: [category_id], references: [id], onDelete: Cascade)
  subcategory        CatalogSubcategory? @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)
  item               CatalogItem?        @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@index([normalized_phrase])
  @@index([category_id, subcategory_id, item_id])
  @@index([normalized_brand, normalized_model])
  @@index([characteristic_key])
  @@unique([normalized_phrase, category_id, subcategory_id, item_id, normalized_brand, normalized_model], map: "CatalogSearchRule_scope_phrase_unique")
}

model CatalogReferenceBrand {
  id             Int                     @id @default(autoincrement())
  public_id      String                  @unique
  item_id        Int
  name           String
  order_index    Int                     @default(0)
  created_at     DateTime                @default(now())
  updated_at     DateTime                @updatedAt

  item           CatalogItem             @relation(fields: [item_id], references: [id], onDelete: Cascade)
  models         CatalogReferenceModel[]

  @@unique([item_id, name])
  @@index([item_id, order_index])
  @@index([name])
}

model CatalogReferenceModel {
  id             Int                       @id @default(autoincrement())
  public_id      String                    @unique
  brand_id       Int
  name           String
  order_index    Int                       @default(0)
  created_at     DateTime                  @default(now())
  updated_at     DateTime                  @updatedAt

  brand          CatalogReferenceBrand     @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  variants       CatalogReferenceVariant[]

  @@unique([brand_id, name])
  @@index([brand_id, order_index])
  @@index([name])
}

model CatalogReferenceVariant {
  id             Int                              @id @default(autoincrement())
  public_id      String                           @unique
  model_id       Int
  external_product_id String?
  title          String
  order_index    Int                              @default(0)
  created_at     DateTime                         @default(now())
  updated_at     DateTime                         @updatedAt

  model          CatalogReferenceModel            @relation(fields: [model_id], references: [id], onDelete: Cascade)
  characteristics CatalogReferenceCharacteristic[]

  @@unique([model_id, external_product_id])
  @@index([model_id, order_index])
  @@index([title])
}

model CatalogReferenceCharacteristic {
  id                 Int                     @id @default(autoincrement())
  variant_id         Int
  key                String
  label              String
  value              String
  raw_value          String
  source_group_index Int
  source             String                  @default("bracketGroups")
  order_index        Int                     @default(0)
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt

  variant            CatalogReferenceVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@index([variant_id, order_index])
  @@index([key])
  @@index([value])
}

model CatalogAttributeDefinition {
  id             Int                 @id @default(autoincrement())
  public_id      String              @unique
  type           ListingType
  category_id    Int?
  subcategory_id Int?
  item_id        Int?
  key            String
  label          String
  input_type     String              @default("text")
  required       Boolean             @default(false)
  options        Json?
  unit           String?
  min_value      Float?
  max_value      Float?
  default_value  String?
  order_index    Int                 @default(0)
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt

  category       CatalogCategory?    @relation(fields: [category_id], references: [id], onDelete: Cascade)
  subcategory    CatalogSubcategory? @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)
  item           CatalogItem?        @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@index([type, category_id])
  @@index([type, subcategory_id])
  @@index([type, item_id])
  @@index([key])
}

model CatalogSuggestion {
  id                      Int                         @id @default(autoincrement())
  public_id               String                      @unique
  entity_type             CatalogSuggestionEntityType
  status                  CatalogSuggestionStatus     @default(PENDING)
  type                    ListingType
  category_id             Int?
  subcategory_id          Int?
  item_id                 Int?
  proposed_by_id          Int?
  raw_value               String
  normalized_value        String
  reason                  String?
  payload                 Json?
  admin_note              String?
  reviewed_by_id          Int?
  reviewed_at             DateTime?
  usage_count             Int                         @default(1)
  merged_target_public_id String?
  created_at              DateTime                    @default(now())
  updated_at              DateTime                    @updatedAt

  category                CatalogCategory?            @relation("catalog_suggestion_category", fields: [category_id], references: [id], onDelete: SetNull)
  subcategory             CatalogSubcategory?         @relation("catalog_suggestion_subcategory", fields: [subcategory_id], references: [id], onDelete: SetNull)
  item                    CatalogItem?                @relation("catalog_suggestion_item", fields: [item_id], references: [id], onDelete: SetNull)
  proposed_by             AppUser?                    @relation("catalog_suggestion_proposer", fields: [proposed_by_id], references: [id], onDelete: SetNull)

  @@unique([entity_type, type, category_id, subcategory_id, normalized_value], map: "CatalogSuggestion_scope_value")
  @@index([status, created_at])
  @@index([entity_type, type])
}

model MarketplaceListing {
  id                   Int               @id @default(autoincrement())
  public_id            String            @unique
  seller_id            Int
  type                 ListingType
  title                String
  description          String?
  item_id              Int?
  price                Int
  sale_price           Int?
  rating               Float             @default(4.5)
  condition            ListingCondition
  status               ListingStatus     @default(ACTIVE)
  moderation_status    ModerationStatus  @default(APPROVED)
  views                Int               @default(0)
  shipping_by_seller   Boolean           @default(true)
  sku                  String?
  tech_grade           String?
  tech_battery_health  Int?
  tech_defects         String?
  tech_included        String?
  photo_count          Int               @default(0)
  photo_front_present  Boolean           @default(false)
  photo_back_present   Boolean           @default(false)
  photo_left_present   Boolean           @default(false)
  photo_right_present  Boolean           @default(false)
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  seller               AppUser           @relation("seller_listings", fields: [seller_id], references: [id], onDelete: Cascade)
  item                 CatalogItem?      @relation(fields: [item_id], references: [id], onDelete: SetNull)
  images               ListingImage[]
  attributes           ListingAttribute[]
  reviews              ListingReview[]
  questions            ListingQuestion[]
  moderation_events    ListingModerationEvent[]
  complaints           Complaint[]
  order_items          MarketOrderItem[]
  wishlist_items       WishlistItem[]
  search_keywords      ListingSearchKeyword[]

  @@index([seller_id])
  @@index([item_id])
  @@index([type, status, moderation_status])
  @@index([status, moderation_status, created_at])
  @@index([type, status, moderation_status, created_at(sort: Desc), id(sort: Desc)], map: "MarketplaceListing_type_status_moderation_created_id_idx")
}

model ListingSearchKeyword {
  id                Int                @id @default(autoincrement())
  listing_id        Int
  phrase            String
  normalized_phrase String
  weight            Int                @default(50)
  source            String             @default("derived")
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  listing           MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@index([listing_id, weight(sort: Desc)])
  @@index([normalized_phrase])
  @@unique([listing_id, normalized_phrase], map: "ListingSearchKeyword_listing_phrase_unique")
}

model ListingDraft {
  id             Int         @id @default(autoincrement())
  public_id      String      @unique
  seller_id      Int
  type           ListingType
  title          String?
  category_id    Int?
  subcategory_id Int?
  item_id        Int?
  payload        Json
  current_screen String
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  seller         AppUser     @relation("seller_listing_drafts", fields: [seller_id], references: [id], onDelete: Cascade)

  @@index([seller_id, updated_at])
  @@index([seller_id, type])
  @@index([item_id])
}

model ListingImage {
  id          Int                @id @default(autoincrement())
  listing_id  Int
  url         String
  sort_order  Int                @default(0)
  created_at  DateTime           @default(now())

  listing     MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([listing_id, sort_order])
}

model ListingAttribute {
  id          Int                @id @default(autoincrement())
  listing_id  Int
  key         String
  value       String
  sort_order  Int                @default(0)

  listing     MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([listing_id, key], map: "ListingAttribute_listing_id_attr_key")
  @@index([listing_id])
}

model ListingModerationEvent {
  id            Int                        @id @default(autoincrement())
  public_id     String                     @unique
  listing_id    Int
  actor_user_id Int?
  actor_type    ListingModerationActorType
  decision      ListingModerationDecision
  reason_code   String
  reason_note   String?
  risk_score    Int?
  signals       Json?
  metadata      Json?
  created_at    DateTime                   @default(now())

  listing       MarketplaceListing         @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  actor         AppUser?                   @relation("listing_moderation_actor", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([listing_id, created_at(sort: Desc), id(sort: Desc)], map: "ListingModerationEvent_listing_created_id_idx")
  @@index([decision, created_at(sort: Desc), id(sort: Desc)], map: "ListingModerationEvent_decision_created_id_idx")
  @@index([reason_code])
}

model ListingReview {
  id          Int      @id @default(autoincrement())
  listing_id  Int
  author_id   Int
  rating      Int
  comment     String
  created_at  DateTime @default(now())

  listing    MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  author     AppUser            @relation("user_reviews", fields: [author_id], references: [id], onDelete: Cascade)

  @@unique([listing_id, author_id])
  @@index([listing_id, created_at])
}

model ListingQuestion {
  id          Int                @id @default(autoincrement())
  public_id   String             @unique
  listing_id  Int
  buyer_id    Int
  question    String
  answer      String?
  status      QuestionStatus     @default(PENDING)
  created_at  DateTime           @default(now())
  answered_at DateTime?

  listing     MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  buyer       AppUser            @relation("question_author", fields: [buyer_id], references: [id], onDelete: Cascade)

  @@index([listing_id, created_at])
}

model WishlistItem {
  id          Int                @id @default(autoincrement())
  user_id     Int
  listing_id  Int
  added_at    DateTime           @default(now())

  user        AppUser            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing     MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([user_id, listing_id])
}

model MarketOrder {
  id                    Int                  @id @default(autoincrement())
  public_id             String               @unique
  buyer_id              Int
  seller_id             Int
  status                OrderStatus          @default(CREATED)
  delivery_type         DeliveryType
  delivery_address      String?
  tracking_provider     String?
  tracking_number       String?
  tracking_url          String?
  delivery_ext_status   String?
  delivery_checked_at   DateTime?
  delivered_at          DateTime?
  issued_at             DateTime?
  total_price           Int
  delivery_cost         Int                  @default(0)
  discount              Int                  @default(0)
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt

  buyer                 AppUser              @relation("buyer_orders", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller                AppUser              @relation("seller_orders", fields: [seller_id], references: [id], onDelete: Cascade)
  items                 MarketOrderItem[]
  transactions          PlatformTransaction[]
  status_history        OrderStatusHistory[]

  @@index([buyer_id])
  @@index([seller_id])
  @@index([status, created_at])
  @@index([delivery_type, status, delivery_checked_at])
}

model MarketOrderItem {
  id          Int                 @id @default(autoincrement())
  order_id    Int
  listing_id  Int?
  name        String
  image       String?
  price       Int
  quantity    Int

  order       MarketOrder         @relation(fields: [order_id], references: [id], onDelete: Cascade)
  listing     MarketplaceListing? @relation(fields: [listing_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([listing_id])
  @@unique([order_id, listing_id], map: "MarketOrderItem_order_listing_unique")
}

model PlatformTransaction {
  id                 Int               @id @default(autoincrement())
  public_id          String            @unique
  order_id           Int
  buyer_id           Int
  seller_id          Int
  amount             Int
  status             TransactionStatus
  commission_rate    Float
  commission         Int
  payment_provider   PaymentProvider
  payment_intent_id  String            @unique
  created_at         DateTime          @default(now())

  order              MarketOrder       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  buyer              AppUser           @relation("buyer_transactions", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller             AppUser           @relation("seller_transactions", fields: [seller_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([buyer_id])
  @@index([seller_id])
  @@index([status, created_at])
}

model Complaint {
  id                    Int                @id @default(autoincrement())
  public_id             String             @unique
  created_at            DateTime           @default(now())
  status                ComplaintStatus    @default(NEW)
  complaint_type        String
  listing_id            Int
  seller_id             Int
  reporter_id           Int
  description           String
  evidence              String?
  checked_at            DateTime?
  checked_by_id         Int?
  action_taken          String?

  listing               MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  seller                AppUser            @relation("complaint_seller", fields: [seller_id], references: [id], onDelete: Cascade)
  reporter              AppUser            @relation("complaint_reporter", fields: [reporter_id], references: [id], onDelete: Cascade)
  checked_by            AppUser?           @relation("complaint_checker", fields: [checked_by_id], references: [id], onDelete: SetNull)
  sanction              ComplaintSanction?
  events                ComplaintEvent[]

  @@index([status])
  @@index([listing_id])
  @@index([status, created_at(sort: Desc), id(sort: Desc)], map: "Complaint_status_created_at_id_idx")
  @@index([listing_id, status, created_at(sort: Desc), id(sort: Desc)], map: "Complaint_listing_status_created_at_id_idx")
}

model ComplaintEvent {
  id            Int              @id @default(autoincrement())
  public_id     String           @unique
  complaint_id  Int
  actor_user_id Int?
  event_type    String
  from_status   ComplaintStatus?
  to_status     ComplaintStatus?
  note          String?
  metadata      Json?
  created_at    DateTime         @default(now())

  complaint     Complaint         @relation(fields: [complaint_id], references: [id], onDelete: Cascade)
  actor         AppUser?          @relation("complaint_event_actor", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([complaint_id, created_at])
  @@index([actor_user_id, created_at])
}

model AdminIdempotencyKey {
  id              Int      @id @default(autoincrement())
  public_id       String   @unique
  actor_user_id   Int
  action          String
  idempotency_key String
  request_hash    String
  response_status Int?
  response_body   Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

