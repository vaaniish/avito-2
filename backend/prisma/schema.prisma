generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AppUser {
  id                   Int                   @id @default(autoincrement())
  public_id            String                @unique
  role                 String
  status               String                @default("ACTIVE")
  email                String                @unique
  password             String
  name                 String
  first_name           String?
  last_name            String?
  display_name         String?
  username             String?
  phone                String?
  city                 String?
  avatar               String?
  block_reason         String?
  joined_at            DateTime              @default(now())
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt

  addresses            UserAddress[]
  listings             MarketplaceListing[]  @relation("seller_listings")
  wishlist_items       WishlistItem[]
  orders_as_buyer      MarketOrder[]         @relation("buyer_orders")
  orders_as_seller     MarketOrder[]         @relation("seller_orders")
  transactions_buyer   PlatformTransaction[] @relation("buyer_transactions")
  transactions_seller  PlatformTransaction[] @relation("seller_transactions")
  questions_asked      ListingQuestion[]     @relation("question_author")
  complaints_reported  Complaint[]           @relation("complaint_reporter")
  complaints_against   Complaint[]           @relation("complaint_seller")
  checked_complaints   Complaint[]           @relation("complaint_checker")
  kyc_requests         KycRequest[]          @relation("kyc_seller")
  reviewed_kyc         KycRequest[]          @relation("kyc_reviewer")
  audit_logs           AuditLog[]            @relation("audit_admin")
  partnership_requests PartnershipRequest[]
}

model UserAddress {
  id          Int      @id @default(autoincrement())
  user_id     Int
  label       String
  region      String
  city        String
  street      String
  building    String
  postal_code String
  is_default  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        AppUser  @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model CatalogCategory {
  id            Int                 @id @default(autoincrement())
  public_id     String              @unique
  type          String
  name          String
  icon_key      String
  order_index   Int                 @default(0)
  created_at    DateTime            @default(now())
  updated_at    DateTime            @updatedAt

  subcategories CatalogSubcategory[]
  listings      MarketplaceListing[]
}

model CatalogSubcategory {
  id             Int                   @id @default(autoincrement())
  category_id    Int
  public_id      String                @unique
  name           String
  order_index    Int                   @default(0)
  created_at     DateTime              @default(now())
  updated_at     DateTime              @updatedAt

  category       CatalogCategory       @relation(fields: [category_id], references: [id], onDelete: Cascade)

}



model MarketplaceListing {
  id                   Int               @id @default(autoincrement())
  public_id            String            @unique
  seller_id            Int
  type                 String
  title                String
  description          String?
  category_id          Int?
  category_name        String
  price                Int
  sale_price           Int?
  rating               Float             @default(4.5)
  condition            String
  status               String            @default("ACTIVE")
  moderation_status    String            @default("APPROVED")
  views                Int               @default(0)
  city                 String
  image                String
  images               String?
  is_new               Boolean           @default(false)
  is_sale              Boolean           @default(false)
  is_verified          Boolean           @default(false)
  shipping_by_seller   Boolean           @default(true)
  sku                  String?
  publish_date         String?
  seller_response_time String?
  seller_listings      Int?
  breadcrumbs          String?
  specifications       String?
  is_price_lower       Boolean           @default(false)
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  seller               AppUser           @relation("seller_listings", fields: [seller_id], references: [id], onDelete: Cascade)
  category             CatalogCategory?  @relation(fields: [category_id], references: [id], onDelete: SetNull)
  reviews              ListingReview[]
  questions            ListingQuestion[]
  complaints           Complaint[]
  order_items          MarketOrderItem[]
  wishlist_items       WishlistItem[]
}

model ListingReview {
  id          Int               @id @default(autoincrement())
  listing_id  Int
  author_name String
  rating      Int
  date        String
  comment     String
  avatar      String?
  created_at  DateTime          @default(now())

  listing     MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
}

model ListingQuestion {
  id          Int               @id @default(autoincrement())
  public_id   String            @unique
  listing_id  Int
  buyer_id    Int
  question    String
  answer      String?
  status      String            @default("PENDING")
  created_at  DateTime          @default(now())
  answered_at DateTime?

  listing     MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  buyer       AppUser            @relation("question_author", fields: [buyer_id], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id          Int               @id @default(autoincrement())
  user_id     Int
  listing_id  Int
  added_at    DateTime          @default(now())

  user        AppUser           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  listing     MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([user_id, listing_id])
}

model MarketOrder {
  id              Int               @id @default(autoincrement())
  public_id       String            @unique
  buyer_id        Int
  seller_id       Int
  status          String
  delivery_type   String
  delivery_address String?
  total_price     Int
  delivery_cost   Int               @default(0)
  discount        Int               @default(0)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  buyer           AppUser           @relation("buyer_orders", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller          AppUser           @relation("seller_orders", fields: [seller_id], references: [id], onDelete: Cascade)
  items           MarketOrderItem[]
  transactions    PlatformTransaction[]
}

model MarketOrderItem {
  id          Int                @id @default(autoincrement())
  order_id    Int
  listing_id  Int?
  name        String
  image       String?
  price       Int
  quantity    Int

  order       MarketOrder        @relation(fields: [order_id], references: [id], onDelete: Cascade)
  listing     MarketplaceListing? @relation(fields: [listing_id], references: [id], onDelete: SetNull)
}

model PlatformTransaction {
  id                 Int               @id @default(autoincrement())
  public_id          String            @unique
  order_id           Int
  buyer_id           Int
  seller_id          Int
  amount             Int
  status             String
  commission_rate    Float
  commission         Int
  payment_provider   String
  payment_intent_id  String
  created_at         DateTime          @default(now())

  order              MarketOrder       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  buyer              AppUser           @relation("buyer_transactions", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller             AppUser           @relation("seller_transactions", fields: [seller_id], references: [id], onDelete: Cascade)
}

model Complaint {
  id                    Int               @id @default(autoincrement())
  public_id             String            @unique
  created_at            DateTime          @default(now())
  status                String            @default("NEW")
  complaint_type        String
  listing_id            Int
  seller_id             Int
  reporter_id           Int
  seller_violations_count Int             @default(0)
  description           String
  evidence              String?
  checked_at            DateTime?
  checked_by_id         Int?
  action_taken          String?

  listing               MarketplaceListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  seller                AppUser            @relation("complaint_seller", fields: [seller_id], references: [id], onDelete: Cascade)
  reporter              AppUser            @relation("complaint_reporter", fields: [reporter_id], references: [id], onDelete: Cascade)
  checked_by            AppUser?           @relation("complaint_checker", fields: [checked_by_id], references: [id], onDelete: SetNull)
}

model KycRequest {
  id              Int       @id @default(autoincrement())
  public_id       String    @unique
  created_at      DateTime  @default(now())
  status          String   @default("PENDING")
  seller_id       Int
  email           String
  phone           String
  company_name    String
  inn             String
  address         String
  documents       String?
  notes           String?
  reviewed_by_id  Int?
  reviewed_at     DateTime?
  rejection_reason String?

  seller          AppUser   @relation("kyc_seller", fields: [seller_id], references: [id], onDelete: Cascade)
  reviewed_by     AppUser?  @relation("kyc_reviewer", fields: [reviewed_by_id], references: [id], onDelete: SetNull)
}

model CommissionTier {
  id              Int       @id @default(autoincrement())
  public_id       String    @unique
  name            String
  min_sales       Int
  max_sales       Int?
  commission_rate Float
  description     String
  sellers_count   Int       @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  public_id   String   @unique
  timestamp   DateTime @default(now())
  admin_id    Int
  action      String
  target_id   String
  target_type String
  details     String
  ip_address  String

  admin       AppUser  @relation("audit_admin", fields: [admin_id], references: [id], onDelete: Cascade)
}

model PartnershipRequest {
  id              Int                   @id @default(autoincrement())
  public_id       String                @unique
  user_id         Int
  seller_type     String
  name            String
  email           String
  contact         String
  link            String
  category        String
  inn             String?
  geography       String?
  social_profile  String?
  credibility     String?
  why_us          String
  created_at      DateTime              @default(now())

  user            AppUser               @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// --- Gamification sandbox models ---

model Partner {
  id                    Int      @id @default(autoincrement())
  name                  String   @default("Test Partner")
  current_xp            Int      @default(0)
  rating                Float    @default(5.0)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  orders                Order[]
  partner_achievements  PartnerAchievement[]
}

model LoyaltyLevel {
  id              Int      @id @default(autoincrement())
  level_name      String   @unique
  xp_threshold    Int      @unique
  xp_coefficient  Float
  created_at      DateTime @default(now())

  orders          Order[]
}

model Order {
  id               Int      @id @default(autoincrement())
  partner_id       Int
  deal_amount      Int
  created_at       DateTime @default(now())
  loyalty_level_id Int

  partner          Partner      @relation(fields: [partner_id], references: [id])
  loyalty_level    LoyaltyLevel @relation(fields: [loyalty_level_id], references: [id])
  xp_accruals      XpAccrual[]
}

model XpAccrual {
  id           Int      @id @default(autoincrement())
  order_id     Int
  xp_amount    Int
  accrual_date DateTime @default(now())
  description  String

  order        Order    @relation(fields: [order_id], references: [id])
}

model Achievement {
  id                   Int      @id @default(autoincrement())
  name                 String   @unique
  description          String
  icon                 String
  xp_reward            Int
  created_at           DateTime @default(now())

  partner_achievements PartnerAchievement[]
}

model PartnerAchievement {
  id             Int      @id @default(autoincrement())
  partner_id     Int
  achievement_id Int
  achieved_date  DateTime @default(now())

  partner        Partner     @relation(fields: [partner_id], references: [id])
  achievement    Achievement @relation(fields: [achievement_id], references: [id])

  @@unique([partner_id, achievement_id])
}
