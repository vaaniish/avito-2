{
  "name": "gamification-sandbox",
  "version": "1.0.0",
  "description": "Gamification sandbox (frontend + backend)",
  "main": "dist/backend/src/server.js",
  "scripts": {
    "postinstall": "npm run db:generate",
    "dev": "npm run dev:all",
    "dev:backend": "node node_modules/tsx/dist/cli.mjs watch backend/src/server.ts",
    "dev:frontend": "node node_modules/vite/bin/vite.js --config frontend/vite.config.ts --host 127.0.0.1 --port 3000 --strictPort",
    "dev:all": "node node_modules/concurrently/dist/bin/concurrently.js \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "node node_modules/typescript/bin/tsc -p backend/tsconfig.json",
    "build:frontend": "node node_modules/vite/bin/vite.js build --config frontend/vite.config.ts",
    "security:preflight:session": "node node_modules/tsx/dist/cli.mjs scripts/quality/security-preflight.session.ts",
    "ci:preflight:prod-auth": "NODE_ENV=production npm run security:preflight:session",
    "perf:stage9": "node scripts/perf/stage9-db.perf.mjs",
    "perf:profile-render-stress": "node node_modules/tsx/dist/cli.mjs --tsconfig frontend/tsconfig.json scripts/perf/profile-render-stress.perf.ts",
    "perf:http-p95:stage10": "node scripts/tests/run-with-backend.mjs -- node scripts/perf/stage10-http.perf.mjs",
    "test:unit": "node node_modules/tsx/dist/cli.mjs --test scripts/tests/unit/*.test.ts",
    "test:integration": "node node_modules/tsx/dist/cli.mjs --test scripts/tests/integration/*.test.ts",
    "test:e2e:smoke": "node scripts/tests/run-with-backend.mjs -- node scripts/tests/e2e/smoke-regression.e2e.mjs",
    "test:e2e:critical": "node scripts/tests/run-with-backend.mjs -- node scripts/tests/e2e/critical-regression.e2e.mjs",
    "test:e2e:phasea": "node scripts/tests/run-with-backend.mjs -- node scripts/tests/e2e/phase-a-critical-flows.e2e.mjs",
    "test:e2e:api:smoke": "npm run test:e2e:smoke",
    "test:e2e:api:critical": "npm run test:e2e:critical && npm run test:e2e:phasea",
    "test:e2e:ui:smoke": "playwright test --config=playwright.config.ts --project=desktop-smoke --project=mobile-smoke --grep @smoke",
    "test:e2e:ui:critical": "playwright test --config=playwright.config.ts --project=desktop-smoke --project=mobile-smoke --grep @critical",
    "test:visual:smoke": "playwright test --config=playwright.config.ts --project=desktop-visual --project=mobile-visual --grep @visual",
    "test:perf:critical": "npm run perf:profile-render-stress && npm run perf:http-p95:stage10",
    "test:security:critical": "npm run security:preflight:session && npm run test:e2e:api:smoke",
    "test:pre-release": "npm run test:unit && npm run test:integration && npm run test:e2e:api:critical && npm run test:e2e:ui:critical && npm run test:visual:smoke && npm run test:perf:critical && npm run test:security:critical",
    "test:critical:e2e": "npm run test:e2e:critical",
    "test:critical": "npm run test:e2e:critical",
    "test:phasea:e2e": "npm run test:e2e:phasea",
    "test:fast": "npm run test:unit && npm run test:integration",
    "qa:phasea": "node scripts/qa/phase-a.qa.mjs",
    "encoding:check": "node scripts/quality/encoding-no-bom.mjs --check",
    "encoding:fix": "node scripts/quality/encoding-no-bom.mjs --fix",
    "ci:verify": "npm run encoding:check && npm run ci:preflight:prod-auth && npm run build",
    "ci:gate:pr": "npm run encoding:check && npm run ci:preflight:prod-auth && npm run build && npm run test:unit && npm run test:integration && npm run test:e2e:api:critical",
    "ci:gate:main": "npm run ci:gate:pr && npm run test:e2e:ui:smoke && npm run test:visual:smoke && npm run test:perf:critical && npm run test:security:critical",
    "ci:gate:pre-release": "npm run ci:gate:main && npm run test:pre-release",
    "start": "node dist/backend/src/server.js",
    "start:dev": "node node_modules/tsx/dist/cli.mjs backend/src/server.ts",
    "db:generate": "node node_modules/prisma/build/index.js generate --schema backend/prisma/schema.prisma",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev --schema backend/prisma/schema.prisma",
    "db:seed": "node node_modules/tsx/dist/cli.mjs backend/prisma/seed.ts",
    "db:import-catalog-reference": "node node_modules/tsx/dist/cli.mjs scripts/catalog/import-catalog-reference-to-db.ts",
    "db:import-search-rules": "node node_modules/tsx/dist/cli.mjs scripts/catalog/import-search-rules-to-db.ts",
    "db:backfill-search-keywords": "node node_modules/tsx/dist/cli.mjs scripts/catalog/backfill-listing-search-keywords.ts",
    "db:push": "node node_modules/prisma/build/index.js db push --schema backend/prisma/schema.prisma",
    "db:migrate:deploy": "node node_modules/prisma/build/index.js migrate deploy --schema backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "0.577.0",
    "motion": "^12.35.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "xlsx-populate": "^1.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "concurrently": "^9.2.1",
    "prisma": "^7.4.2",
    "react-test-renderer": "^19.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
