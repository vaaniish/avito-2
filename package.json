{
  "name": "gamification-sandbox",
  "version": "1.0.0",
  "description": "Gamification sandbox (frontend + backend)",
  "main": "backend/src/server.ts",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:backend": "tsx watch backend/src/server.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts --host 127.0.0.1 --port 3000",
    "dev:all": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "start": "tsx backend/src/server.ts",
    "db:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "db:seed": "tsx backend/prisma/seed.ts",
    "db:push": "prisma db push --schema backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "lucide-react": "^0.576.0",
    "motion": "^12.23.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.35",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.2",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
